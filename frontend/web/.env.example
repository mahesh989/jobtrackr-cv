# ══════════════════════════════════════════════════════════════════════
# frontend/web environment — copy to .env.local and fill in.
# Every variable the code reads (grep: process.env.*) is listed here.
# Never commit real values.
# ══════════════════════════════════════════════════════════════════════

# ── Supabase (required) ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# ── Site URLs (required) ───────────────────────────────────────────────
# Local dev: http://localhost:3000 · Production: the Vercel URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── cv-backend bridge (required for CV/analysis features) ──────────────
# HMAC-signed internal API — see lib/cv/backend.ts
CV_BACKEND_URL=https://jobtrackr-cv-api.fly.dev
JOBTRACKR_HMAC_SECRET=<shared-hmac-secret>

# ── Worker queue (required for "Run now" / "Full refresh") ─────────────
# Upstash Redis connection string used to enqueue pipeline jobs
# (app/api/profiles/[id]/run). Missing → run requests 500.
REDIS_URL=rediss://default:<password>@<host>:<port>

# ── Credential encryption (required for Apify/AI key storage) ──────────
# 32 random bytes, hex. Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTEGRATION_ENCRYPTION_KEY=<64-hex-chars>

# ── Stripe (required for billing) ──────────────────────────────────────
# Test keys locally (sk_test_...); webhook secret comes from
# `stripe listen` locally or the dashboard endpoint config in prod.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_WEEKLY=price_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_UNLIMITED=price_...

# ── Email OAuth (optional — Gmail/Outlook send integration) ────────────
GOOGLE_CLIENT_ID=<google-oauth-client-id>
GOOGLE_CLIENT_SECRET=<google-oauth-client-secret>
MICROSOFT_CLIENT_ID=<azure-app-client-id>
MICROSOFT_CLIENT_SECRET=<azure-app-client-secret>

# ── Google Places (optional — profile location autocomplete) ───────────
PLACES_API_KEY=<google-places-api-key>

# ── Cloudflare Turnstile (optional — login/signup bot protection) ──────
# Unset locally = captcha UI hidden; must also be disabled in the
# Supabase dashboard for local email/password login to work.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=<turnstile-site-key>
