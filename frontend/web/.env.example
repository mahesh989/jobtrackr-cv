# Supabase (public — ok to expose)
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Server-only
# Service-role key bypasses RLS — NEVER commit a real one. Copy from
# Supabase → Project Settings → API. Keep it only in the deployment secret store.
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Upstash Redis (server-only, for /api/profiles/[id]/run enqueue endpoint)
REDIS_URL=redis://default:<password>@<your-db>.upstash.io:6379
