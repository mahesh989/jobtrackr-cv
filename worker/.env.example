# Upstash Redis (free tier)
# From: https://console.upstash.com → Databases → your db → "Redis Connect" → ioredis
REDIS_URL=redis://default:<password>@<your-db>.upstash.io:6379


# Supabase
SUPABASE_URL=https://<your-project-ref>.supabase.co
# Service-role key bypasses RLS — NEVER commit a real one. Copy from
# Supabase → Project Settings → API. Keep it only in the deployment secret store.
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# AI provider — "openai" (dev) or "anthropic" (production)
AI_PROVIDER=openai

# OpenAI — used when AI_PROVIDER=openai (gpt-4o-mini)
OPENAI_API_KEY=

# Anthropic — used when AI_PROVIDER=anthropic (claude-haiku-4-5 Batch API)
ANTHROPIC_API_KEY=

# Adzuna (Phase 2+)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Resend (Phase 6+)
# USER ACTION: Create account at resend.com, verify sender domain, then fill in:
RESEND_API_KEY=
RESEND_FROM_EMAIL=JobTrackr <noreply@yourdomain.com>
