    "ioredis": "^5.4.1",
    "openai": "^6.37.0",
    "playwright-core": "^1.60.0",
    "resend": "^6.12.3"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "playwright": "^1.60.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
