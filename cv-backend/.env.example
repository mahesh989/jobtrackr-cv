# =============================================================================
# CV Magic API — Environment Variables
# Copy this file to .env and fill in real values before running the server.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — PostgreSQL + Storage
# -----------------------------------------------------------------------------

# Your Supabase project URL (e.g. https://xyzcompany.supabase.co)
SUPABASE_URL=https://xxxx.supabase.co

# Supabase anon/public key — safe to expose in frontend, used for public ops
SUPABASE_ANON_KEY=xxxx

# Supabase service role key — NEVER expose publicly, grants full DB access
SUPABASE_SERVICE_ROLE_KEY=xxxx

# Async PostgreSQL connection URL for SQLAlchemy (uses asyncpg driver)
# Format: postgresql+asyncpg://user:password@host:port/dbname
# Find this in Supabase → Settings → Database → Connection String (URI)
SUPABASE_DB_URL=postgresql+asyncpg://postgres.xxxx:xxxx@aws-0-xxxx.pooler.supabase.com:6543/postgres

# -----------------------------------------------------------------------------
# Clerk — Authentication
# -----------------------------------------------------------------------------

# Clerk secret key (sk_live_... or sk_test_...)
# Find in Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx

# Webhook signing secret for verifying incoming Clerk webhooks
# Create in Clerk Dashboard → Webhooks → your endpoint → Signing Secret
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxxx

# Clerk JWKS URL for JWT verification (auto-constructed from your Frontend API)
# Format: https://<your-clerk-frontend-api>/.well-known/jwks.json
CLERK_JWKS_URL=https://xxxx.clerk.accounts.dev/.well-known/jwks.json

# -----------------------------------------------------------------------------
# Sentry — Error Monitoring
# -----------------------------------------------------------------------------

# Sentry DSN — leave blank to disable Sentry in development
# Find in Sentry Dashboard → Project → Settings → Client Keys (DSN)
SENTRY_DSN=https://your-key@sentry.io/your-project-id

# -----------------------------------------------------------------------------
# AI Providers
# -----------------------------------------------------------------------------

# At least one is required. Users select provider/model in the app, but the
# server holds the keys.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...

# Default when a user has no preference saved
DEFAULT_AI_PROVIDER=anthropic
DEFAULT_AI_MODEL=claude-3-5-sonnet-20241022

# -----------------------------------------------------------------------------
# Resend — Transactional Email
# -----------------------------------------------------------------------------

# Resend API key for sending emails — leave blank to disable email
# Find in Resend Dashboard → API Keys
RESEND_API_KEY=re_...

# Verified sender address (must match a domain you've verified in Resend)
RESEND_FROM_EMAIL=CV Magic <noreply@cvmagic.app>

# Public app URL — used for links in transactional emails (e.g. /analysis/{id})
APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Stripe — Billing
# -----------------------------------------------------------------------------

# Stripe secret key (sk_live_... or sk_test_...)
STRIPE_SECRET_KEY=sk_test_...

# Stripe publishable key — exposed via /billing/config to the frontend
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook signing secret. For local dev: `stripe listen --forward-to localhost:8000/api/v1/billing/webhook`
STRIPE_WEBHOOK_SIGNING_SECRET=whsec_...

# Stripe Price ID for the Pro plan (find in Stripe Dashboard → Products)
STRIPE_PRO_PRICE_ID=price_...

# Optional — paths the user is redirected to after checkout (relative to APP_URL)
STRIPE_BILLING_SUCCESS_PATH=/billing/success
STRIPE_BILLING_CANCEL_PATH=/billing/cancel

# -----------------------------------------------------------------------------
# CORS — Cross-Origin Resource Sharing
# -----------------------------------------------------------------------------

# JSON array of allowed origins for CORS.
# In production this should be your frontend URL(s) only.
# Example: '["https://cvmagic.app", "https://www.cvmagic.app"]'
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# Environment name: "development" or "production"
ENVIRONMENT=development

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
