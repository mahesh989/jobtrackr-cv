# cv-backend — internal Python service, deployed at jobtrackr-cv-api.fly.dev
# Only JobTrackr's Next.js API routes ever call this service (HMAC-signed).

# ─── Supabase (shared with JobTrackr) ───
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=postgresql+asyncpg://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# ─── Storage buckets ───
SUPABASE_CV_BUCKET=cvs
SUPABASE_TAILORED_CV_BUCKET=tailored-cvs

# ─── HMAC shared secret with JobTrackr ───
# Generate: openssl rand -hex 32
# Must match JOBTRACKR_HMAC_SECRET on Vercel.
JOBTRACKR_HMAC_SECRET=

# ─── Sentry (optional) ───
SENTRY_DSN=

# ─── App ───
ENVIRONMENT=development
LOG_LEVEL=INFO
ALLOWED_ORIGINS=["http://localhost:3000"]
