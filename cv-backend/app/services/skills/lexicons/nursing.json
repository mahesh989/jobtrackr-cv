  "_meta": {
    "vertical": "nursing / health (AIN, PCW, aged care, home care, disability support, clinical care)",
    "purpose": "Canonical skill taxonomy for the nursing/health vertical. A phrase that resolves here gets its `category` from THIS table — the LLM never decides the category. The same table classifies BOTH the CV and the JD, so a skill is bucketed identically on both sides.",
    "category_keys": {
      "domain_knowledge": "Clinical / care competencies — the WHAT-FIELD. Renders as the headline 'Care Skills' / 'Clinical Skills' line for nursing.",
      "soft_skills": "Interpersonal / behavioural. Renders as 'Soft Skills'.",
      "technical": "Named care SOFTWARE / SYSTEMS and generic computing — the named PRODUCT, never the clinical activity. Renders as the secondary 'Other Skills' line for nursing."
    },
    "rules": {
      "activity_vs_product": "A clinical ACTIVITY (e.g. 'electronic medication administration') is domain_knowledge. The SOFTWARE that performs it ('BESTMed', 'MedMobile') is technical.",
      "variants": "Each entry's `variants` are alternate surface forms that all resolve to `canonical`. This list IS the synonym map used by deterministic CV-JD matching.",
      "credentials_excluded": "Licences / checks / vaccinations are NOT here — they live in _universal_noise.json (type=credential) and route to Registration & Licences."
    },
    "review_status": "DRAFT — Phase 0 seed (~ correct order of magnitude). Add the long tail as real runs surface misses (safe-drop + log). Seeded from the CV categoriser vocabulary + the Hardi/Nepean/Rashmi runs."
  },

