# cv-backend — internal Python service, deployed at jobtrackr-cv-api.fly.dev
# Only JobTrackr's Next.js API routes ever call this service (HMAC-signed).

# ─── Supabase (shared with JobTrackr) ───
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Storage buckets ───
SUPABASE_CV_BUCKET=cvs
SUPABASE_TAILORED_CV_BUCKET=tailored-cvs

# ─── HMAC shared secret with JobTrackr ───
# Generate: openssl rand -hex 32
# Must match JOBTRACKR_HMAC_SECRET on Vercel.
JOBTRACKR_HMAC_SECRET=

# ─── Tavily web search (system-level key — NOT user-supplied) ───
# Used by company research pipeline (Phase 10.3).
# Leave empty to fall back to direct website scraping only.
# Get a key at https://tavily.com (generous free tier: 1000 req/month)
TAVILY_API_KEY=

# ─── Sentry (optional) ───
SENTRY_DSN=

# ─── AI defaults (BYOK — the actual key arrives per-request from JobTrackr) ───
DEFAULT_AI_PROVIDER=anthropic
DEFAULT_AI_MODEL=claude-3-5-sonnet-20241022

# ─── Tailored-CV writer selection ───
# "w8_verified" (default) — role-family composition + deterministic enforce +
# entailment verify. "legacy" — the original single-call writer (escape hatch).
TAILORED_CV_WRITER=w8_verified

# ─── Pipeline concurrency ───
# Max analysis pipelines doing real work simultaneously; excess runs queue on a
# semaphore (still 202-accepted instantly). Raise carefully — too high
# re-introduces the bulk-run stampede on Supabase + the user's AI-key rate limit.
MAX_CONCURRENT_ANALYSES=4

# ─── AI usage observability (read via os.getenv, not Settings) ───
# 'true' → emit one ai_calls row per LLM call (requires migration 055).
TRACK_AI_USAGE=false

# ─── Lexicon-gap tracking (read via os.getenv, not Settings) ───
# JSONL log of unknown skill phrases; production should point at a persistent disk.
UNKNOWN_PHRASES_LOG=/tmp/jobtrackr_unknown_phrases.jsonl

# ─── App ───
ENVIRONMENT=development
LOG_LEVEL=INFO
ALLOWED_ORIGINS=["http://localhost:3000"]
